# =============================================================================
# Poodll Media Server — Region Config Template
# Copy this to e.g. deploy/region-eu.conf and fill in all values.
# This file contains secrets — do NOT commit it to git.
# =============================================================================

# ── Region identity ───────────────────────────────────────────────────────────
AWS_REGION="eu-west-1"         # eu-west-1 | us-east-1 | ap-northeast-1 | cn-northwest-1
AWS_PROFILE="aws-global"       # Name of the AWS CLI profile to use locally
MEDIA_DOMAIN="media-eu.poodll.io"


# ── EC2 networking ────────────────────────────────────────────────────────────
# Your AWS account's default VPC and a public subnet in that region.
# Find these in: AWS Console → VPC → Your VPCs / Subnets
VPC_ID="vpc-xxxxxxxxxxxxxxxxx"
SUBNET_ID="subnet-xxxxxxxxxxxxxxxxx"

# Your current public IP (for SSH access only — keeps port 22 locked down)
# Find it at: curl https://checkip.amazonaws.com
YOUR_IP="1.2.3.4"

# ── EC2 instance ──────────────────────────────────────────────────────────────
# g4dn.xlarge = T4 GPU (available in all regions including China)
# g6.xlarge   = L4 GPU (NOT available in cn-northwest-1)
INSTANCE_TYPE="g4dn.xlarge"

# Name of your EC2 SSH key pair (create in EC2 → Key Pairs if needed)
KEY_PAIR_NAME="poodll-media-key"

# ── Resource names (change per region to avoid conflicts) ─────────────────────
IAM_ROLE_NAME="poodll-media-server-role"       # same across regions (IAM is global)
SG_NAME="poodll-media-server-sg-eu"
LAUNCH_TEMPLATE_NAME="poodll-media-server-eu"
ASG_NAME="poodll-media-server-eu"

# ── Route 53 ─────────────────────────────────────────────────────────────────
# Your hosted zone for poodll.io
# Find it at: aws route53 list-hosted-zones --query "HostedZones[?Name=='poodll.io.'].Id"

HOSTED_ZONE_ID="Z1234567890ABCDEF"

# ── Git repository ────────────────────────────────────────────────────────────
# The EC2 instance clones this at boot time
REPO_URL="https://github.com/poodll/poodll-media-server.git"

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16  (key)
#                openssl rand -hex 32  (secret — must be 32+ bytes)
LIVEKIT_API_KEY="changeme-key-eu"
LIVEKIT_API_SECRET="changeme-secret-at-least-32-chars-eu"

# ── S3 credentials (for Poodll bucket writes) ─────────────────────────────────
# Prefix with MEDIA_ to avoid shadowing the deploying user's own AWS credentials
MEDIA_AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
MEDIA_AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# ── CloudPoodll + Caddy ───────────────────────────────────────────────────────
ADMIN_EMAIL="woof@poodll.com"
CLOUDPOODLL_URL="https://cloud.poodll.com"  # use https://cloud.poodll.cn for China



# ── Whisper Model ─────────────────────────────────────────────────────────────
# Normal sizes: tiny | base | small | medium | large-v3
# Use 'large-v3' for highest quality (required for G4dn/G6 GPUs)
WHISPER_MODEL_SIZE="large-v3"
WHISPER_DEVICE="cuda"           # 'cuda' for GPU, 'cpu' for non-GPU testing
WHISPER_COMPUTE_TYPE="float16" # 'float16' for GPU, 'int8' for CPU
