# =============================================================================
# Poodll Media Server — Production Environment Template
# Copy to .env.prod and fill in all values before deploying.
# This file must NOT be committed to git.
# =============================================================================

# ---------------- LiveKit --------------------------------------------------
# Generate strong random values: openssl rand -hex 32
LIVEKIT_API_KEY=changeme-key
LIVEKIT_API_SECRET=changeme-secret-at-least-32-chars

# Internal URL (within Docker network — never changes)
LIVEKIT_URL=ws://livekit-server:7880

# Public WSS URL returned to browsers (must match your domain)
# EU:  wss://media-eu.poodll.io:7880
# US:  wss://media-us.poodll.io:7880
# AP:  wss://media-ap.poodll.io:7880
# CN:  wss://media-cn.poodll.cn:7880
LIVEKIT_PUBLIC_URL=wss://media-eu.poodll.io:7880


# ---------------- AWS S3 ---------------------------------------------------
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Region of THIS server (drives bucket selection)
# EU:     eu-west-1
# US:     us-east-1
# AP:     ap-northeast-1
# CN:     cn-northwest-1
AWS_REGION=eu-west-1

# (Legacy — no longer used for bucket selection, kept for boto3 client init)
S3_BUCKET=poodll-audioprocessing-out-eu-west-1

# ---------------- CloudPoodll ----------------------------------------------
# Global: https://cloud.poodll.com | China: https://cloud.poodll.cn
CLOUDPOODLL_URL=https://cloud.poodll.com


# Cache TTLs (seconds) — tune if needed
AUTH_CACHE_TTL_OK=3600
AUTH_CACHE_TTL_FAIL=60

# ---------------- Redis (internal) ----------------------------------------
REDIS_URL=redis://redis:6379

# ---------------- Caddy TLS ------------------------------------------------
# Your email for Let's Encrypt certificate notifications
ADMIN_EMAIL=woof@poodll.com


# Domain for this deployment (drives Caddyfile)
MEDIA_DOMAIN=media-eu.poodll.io


# ---------------- Optional Callback ----------------------------------------
# Leave empty to disable the recording-ready HTTP callback
RECORDING_READY_URL=
